{
  "manifest_version": 3,
  "name": "Multi-Prompt Split View",
  "version": "1.0",
  "description": "Send a single prompt to two AI chatbots simultaneously using Chrome split view windows.",
  "permissions": [
    "tabs",
    "windows",
    "storage",
    "bookmarks"
  ],
  "host_permissions": [
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configure Multi-Prompt"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/app*"],
      "js": ["content/common.js", "content/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://claude.ai/*"],
      "js": ["content/common.js", "content/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://chatgpt.com/*"],
      "js": ["content/common.js", "content/chatgpt.js"],
      "run_at": "document_idle"
    }
  ]
}
